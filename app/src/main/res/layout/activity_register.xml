<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ImageView android:id="@+id/imgLogoReg" android:layout_width="140dp" android:layout_height="140dp" android:layout_marginTop="64dp" android:src="@drawable/logo" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>

    <TextView android:id="@+id/tvRegTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="DAFTAR" android:textColor="@color/blue_primary" android:textSize="24sp" android:textStyle="bold" android:fontFamily="serif" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/imgLogoReg"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFormReg"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/card_brown"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvRegTitle">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="32dp" android:paddingVertical="36dp">

            <EditText android:id="@+id/etUsernameReg" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/line_bottom_black" android:hint="Username" android:textColorHint="@color/black" android:textColor="@color/black" android:textSize="14sp" android:textStyle="bold" android:paddingBottom="8dp" android:layout_marginBottom="20dp"/>

            <EditText
                android:id="@+id/etNamaReg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/line_bottom_black"
                android:hint="Nama"
                android:inputType="textPersonName"
                android:textColorHint="@color/black"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="8dp"
                android:layout_marginBottom="20dp"/>

            <EditText android:id="@+id/etPasswordReg" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/line_bottom_black" android:hint="Password" android:inputType="textPassword" android:textColorHint="@color/black" android:textColor="@color/black" android:textSize="14sp" android:textStyle="bold" android:paddingBottom="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tombol Daftar yang sudah berbentuk Kapsul -->
    <Button
        android:id="@+id/btnRegister"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="@android:color/white"
        android:text="Daftar"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        app:strokeColor="#DDDDDD"
        app:strokeWidth="1dp"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardFormReg"/>

    <!-- Teks Link ke Login -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnRegister"> <!-- ID diganti ke btnRegister agar tidak merah -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUDAH MEMILIKI AKUN? "
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvGoToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOGIN"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>